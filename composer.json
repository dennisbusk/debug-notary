{
    "name": "dennisbusk/debug-notary",
    "description": "A Laravel package for debug notarization.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Dennis Busk",
            "email": "dennisbusk@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dennisbusk\\DebugNotary\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dennisbusk\\DebugNotary\\DebugNotaryServiceProvider"
            ],
            "aliases": {
                "DebugNotary": "Dennisbusk\\DebugNotary\\Facades\\DebugNotary"
            }
        }
    }
}
